# ── Transporte ───────────────────────────────────────────────────────────────
# stdio          → uso local (Claude Code desktop)
# sse            → HTTP SSE, compatível com a maioria dos clientes MCP
# streamable-http → HTTP moderno (recomendado para VPS)
MCP_TRANSPORT=streamable-http

# ── Rede ─────────────────────────────────────────────────────────────────────
MCP_HOST=0.0.0.0
MCP_PORT=8000
